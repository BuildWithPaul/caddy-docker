# Caddyfile — reverse proxy config
# Replace paul-sandbox.duckdns.org with your domain
# Add handle_path blocks for each service
#
# Set ENABLE_ACCESS_LOGS=true in .env to see request logs.
# Default: only errors are logged (ERROR level).

paul-sandbox.duckdns.org {
	log {
		output stdout
		format console
		level {$ENABLE_ACCESS_LOGS:ERROR}
	}

	# ── VitaminChecker ──────────────────────────────────────────
	handle_path /vitaminchecker/* {
		reverse_proxy vitaminchecker:5000 {
			header_up X-Script-Name /vitaminchecker
		}
	}
	redir /vitaminchecker /vitaminchecker/ permanent

	# ── ChouChouAlerte (lowercase path) ─────────────────────────
	handle_path /chouchoualerte/* {
		reverse_proxy chouchoualerte:5001 {
			header_up X-Script-Name /chouchoualerte
		}
	}
	redir /chouchoualerte /chouchoualerte/ permanent

	# ── ChouChouAlerte (mixed-case redirect) ─────────────────────
	redir /ChouChouAlerte /chouchoualerte/ permanent
	redir /ChouChouAlerte/* /chouchoualerte/{path.1} permanent

	# ── Default: redirect root to VitaminChecker ────────────────
	redir / /vitaminchecker/ permanent

	# Add more services here:
	# handle_path /another-app/* {
	# 	reverse_proxy another-app:3000 {
	#       header_up X-Script-Name /another-app
	#   }
	# }
	# redir /another-app /another-app/ permanent
}